# Zoho OAuth2 credentials (DEPRECATED — use ZOHO_AMZG_* instead.
# Kept for the legacy zoho-invoice-agent path; will be removed in Phase 1.)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Zoho Books organization ID (DEPRECATED — see ZOHO_AMZG_ORGANIZATION_ID below)
ZOHO_ORGANIZATION_ID=

# Data center URLs (defaults to US — change if your Zoho is on .eu, .in, .com.au, etc.)
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com/books/v3

# Default customer/item for batch creation (optional — can also specify per row in Excel)
ZOHO_DEFAULT_CUSTOMER_ID=
ZOHO_DEFAULT_ITEM_ID=
ZOHO_PAYMENT_TERMS=30

# Scheduler (server mode only)
SCHEDULER_ENABLED=false
SCHEDULER_RECURRING_CRON=

# Gmail Automation (auto-create invoices from Wise transfer emails)
GMAIL_ENABLED=false
GMAIL_CREDENTIALS_B64=
GMAIL_TOKEN_B64=
GMAIL_LABEL_NAME=Pacific wise transfers

# Telegram Notifications (optional — get notified when invoices are created)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================================
# Goldman — multi-entity Zoho credentials (preferred for v1)
# ============================================================================
# AMZ Expert Global Limited (Hong Kong parent) — credential key "AMZG"
ZOHO_AMZG_CLIENT_ID=
ZOHO_AMZG_CLIENT_SECRET=
ZOHO_AMZG_REFRESH_TOKEN=
ZOHO_AMZG_ORGANIZATION_ID=
# Optional overrides per entity (defaults match Zoho US data center)
# ZOHO_AMZG_ACCOUNTS_URL=https://accounts.zoho.com
# ZOHO_AMZG_API_BASE_URL=https://www.zohoapis.com/books/v3

# Specific Edge Outsourcing LLC (US subsidiary) — credential key "SEO"
ZOHO_SEO_CLIENT_ID=
ZOHO_SEO_CLIENT_SECRET=
ZOHO_SEO_REFRESH_TOKEN=
ZOHO_SEO_ORGANIZATION_ID=

# ============================================================================
# Goldman Postgres (shared HQ Hub Supabase project, isolated 'goldman' schema)
# ============================================================================
# Admin URL — used by migrations and admin scripts only.
GOLDMAN_DB_ADMIN_URL=
# App URL — runtime queries authenticate as goldman_app_login role.
GOLDMAN_DB_APP_URL=

# ============================================================================
# Goldman Phase 2 — embeddings, summarisation, storage
# ============================================================================
# OpenAI for text-embedding-3-small (1536d). Same key HQ Hub / Atlas uses.
OPENAI_API_KEY=

# Anthropic key already set above (Phase 1) — reused for DocumentSummariser.

# Supabase Storage (service-role for goldman bucket access).
# URL = https://tjxngrplgiqicdorsjzr.supabase.co  (the HQ Hub project URL)
GOLDMAN_SUPABASE_URL=
# Service-role key (admin-level, NEVER commit). Find in Supabase dashboard
# -> Project Settings -> API -> service_role secret.
GOLDMAN_SUPABASE_SERVICE_KEY=

# ============================================================================
# Goldman Phase 3 — Google Drive + Gmail (for vendor-bill intake)
# ============================================================================
# Google Drive OAuth — base64'd pickled google-auth Credentials object.
# Same pattern as Bob's GOOGLE_TOKEN_B64. Easiest path: generate locally via
# a one-time OAuth flow with the drive.file scope.
GOLDMAN_DRIVE_TOKEN_B64=

# (Gmail intake reuses existing GMAIL_CREDENTIALS_B64 / GMAIL_TOKEN_B64.)
